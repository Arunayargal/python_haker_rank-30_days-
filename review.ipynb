    "t = int(input())\n",
    "\n",
    "for _ in range(t):\n",
    "    s = input()\n",
    "\n",
    "    even = s[::2]   # characters at even indices\n",
    "    odd = s[1::2]   # characters at odd indices\n",
    "\n",
    "    print(even, odd)"
   ]
  }
